{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables default permissions and OpenWeatherMap access",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://api.openweathermap.org/*"
        },
        {
          "url": "https://openweathermap.org/*"
        }
      ]
    }
  ]
}
